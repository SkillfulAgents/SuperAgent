{
  "name": "superagent",
  "version": "0.3.3-rc.2",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm rebuild better-sqlite3 && vite",
    "dev:web": "vite",
    "dev:api": "tsx watch src/web/server.ts",
    "dev:electron": "electron-rebuild -f && electron-vite dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "tsup",
    "build:electron": "electron-vite build",
    "preview": "npm run build && node dist/web/server.mjs",
    "download:lima": "bash scripts/download-lima.sh",
    "download:wsl-rootfs": "bash scripts/download-wsl-rootfs.sh",
    "dist:mac": "npm run download:lima && electron-vite build && electron-builder --mac --publish never",
    "dist:win": "npm run download:wsl-rootfs && electron-vite build && electron-builder --win --publish never",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:container": "npm --prefix agent-container test",
    "test:e2e": "E2E_MOCK=true playwright test --project=web-chromium",
    "test:e2e:headed": "E2E_MOCK=true playwright test --project=web-chromium --headed",
    "test:e2e:ui": "E2E_MOCK=true playwright test --ui",
    "test:e2e:auth": "npx playwright test --config=playwright.auth.config.ts",
    "test:e2e:electron": "npm run build:electron && E2E_MOCK=true playwright test --project=electron",
    "test:e2e:perf": "RENDER_TRACKING=true E2E_MOCK=true playwright test --project=web-chromium e2e/specs/render-perf.spec.ts",
    "db:reset": "rm superagent.db* && drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "build:container": "docker build -t superagent-container ./agent-container",
    "icons:download": "tsx scripts/download-service-icons.ts"
  },
  "dependencies": {
    "@analytics/amplitude": "^0.1.3",
    "@analytics/google-analytics": "^1.1.0",
    "@analytics/mixpanel": "^0.4.0",
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.13.7",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@skillful-agents/agent-computer": "^0.0.11",
    "@tanstack/react-query": "^5.56.0",
    "@types/react-file-icon": "^1.0.4",
    "adm-zip": "^0.5.16",
    "analytics": "^0.8.19",
    "archiver": "^7.0.1",
    "better-auth": "^1.4.19",
    "better-sqlite3": "^12.8.0",
    "ccusage": "^15.2.0",
    "chrono-node": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.7.3",
    "eventsource": "^4.1.0",
    "fflate": "^0.8.2",
    "hono": "^4.6.14",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.446.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-file-icon": "^1.6.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@electron/rebuild": "^3.7.2",
    "@hono/vite-dev-server": "^0.24.1",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/eventsource": "^1.1.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@welldone-software/why-did-you-render": "^8.0.3",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.1.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.superagent.app",
    "productName": "Superagent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/@skillful-agents/agent-computer/bin/**"
    ],
    "extraResources": [
      {
        "from": "src/shared/lib/db/migrations",
        "to": "migrations"
      },
      {
        "from": "build",
        "to": "tray-icons",
        "filter": [
          "tray*",
          "status_*",
          "icon*"
        ]
      },
      {
        "from": "build/lima",
        "to": "lima",
        "filter": [
          "bin/limactl",
          "share/lima/lima-guestagent*",
          "alpine.qcow2"
        ]
      },
      {
        "from": "build/wsl2",
        "to": "wsl2",
        "filter": [
          "alpine-rootfs-x86_64.tar.gz",
          "alpine-rootfs-aarch64.tar.gz"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Superagent-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icon",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Superagent",
      "uninstallDisplayName": "Superagent",
      "artifactName": "Superagent-Setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "SkillfulAgents",
      "repo": "SuperAgent"
    }
  }
}
