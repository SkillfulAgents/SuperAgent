# Anthropic API Key - Required
# This key is passed to the Docker containers to authenticate with the Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Anthropic Base URL (for proxy or enterprise setups)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Database path (optional, defaults to ./superagent.db)
# DATABASE_PATH=./superagent.db

# Container Status Sync
# How often to sync container status with Docker/Podman (in seconds)
# Lower values = more responsive UI, higher values = less Docker CLI overhead
# CONTAINER_STATUS_SYNC_INTERVAL_SECONDS=300

# Runner Availability Cache
# How long to cache Docker/Podman availability checks (in seconds)
# RUNNER_AVAILABILITY_CACHE_TTL_SECONDS=60

# Platform: Base URL for the platform web app (login / auth exchange)
# PLATFORM_BASE_URL=https://platform.example.com

# Platform: Proxy URL used by the LLM provider, STT provider, and Composio client
# PLATFORM_PROXY_URL=https://platform-proxy.example.com

# Auth providers: managed deployments receive this JSON from the platform-issued env bundle.
# AUTH_PROVIDERS_JSON=[{"id":"platform","type":"oidc","displayName":"Platform","issuer":"https://auth.example.com","clientId":"superagent-local","clientSecret":"","scopes":["openid","profile","email","offline_access"]}]

# Analytics: Amplitude API key for anonymous usage analytics (baked in at build time)
# AMPLITUDE_API_KEY=
